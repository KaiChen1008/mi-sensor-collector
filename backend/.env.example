# App
APP_HOST=0.0.0.0
APP_PORT=8002
SCAN_INTERVAL_SECONDS=60
SIMULATE_SENSORS=false

# Email (SMTP) — e.g. Gmail with App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com

# Telegram Bot
# 1. Message @BotFather on Telegram to create a bot → get BOT_TOKEN
# 2. Start a conversation with your bot, then call:
#    https://api.telegram.org/bot<BOT_TOKEN>/getUpdates  → find your chat_id
TELEGRAM_BOT_TOKEN=

# LINE Notify
# Get a personal access token at https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=
